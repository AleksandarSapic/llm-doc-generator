# Dependencies — reinstalled via npm ci inside the container
node_modules/

# Previous build output — the container builds fresh
dist/

# Angular cache
.angular/

# Version control
.git/
.gitignore

# Environment files — never bake secrets into the image
.env*

# IDE and editor artifacts
.idea/
.vscode/
*.iml

# Test and coverage artifacts
coverage/
*.spec.ts

# Documentation
*.md

# Logs
*.log
npm-debug.log*
